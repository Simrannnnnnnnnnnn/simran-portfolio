{
  "version": 2,
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/chat.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/chat", "dest": "/api/chat.js" },
    { "src": "/style.css", "dest": "/public/style.css" },
    { "src": "/script.js", "dest": "/public/script.js" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}